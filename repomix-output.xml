    const regexStr = `("${lang}"|${lang})\\s*:\\s*\\{([\\s\\S]*?)(^\\s*\\})?`;
    const regex = new RegExp(`("${lang}"|${lang})\\s*:\\s*\\{([^\\}]*?)\\n(\\s*)\\}`, 'gm');
    
    content = content.replace(regex, (match, p1, p2, p3) => {
        // match contains the whole block
        // wait, [^\}]* doesn't work if there are nested braces
        return match; 
    });
