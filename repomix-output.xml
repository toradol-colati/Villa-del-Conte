        # inside parts[1], the first occurrence of '\n    },' or '\n    }' is the end of the block
        subparts = re.split(r'\n\s*}(?:,|$)', parts[1], 1)
        
        # reconstruct
        new_block = subparts[0] + ",\n" + additions_str + "\n    }" + ("," if len(parts[1]) > len(subparts[0]) + 10 else "")
